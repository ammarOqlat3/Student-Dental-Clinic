﻿@{
ViewData["Title"] = "Dental Clinic System";
}

@section Styles {
    <link rel="stylesheet" href="~/css/index.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container h-100 position-relative">
        <div class="row h-100 align-items-center">
            <div class="col-lg-8 mx-auto text-center text-white">
                <div class="hero-content">
                    <span class="hero-badge mb-3 d-inline-block">
                        <i class="bi bi-shield-heart me-1"></i> Professional Dental Care
                    </span>
                    <h1 class="display-3 fw-bold mb-4">
                        Your Smile, <br>
                        <span class="text-gradient">Our Priority</span>
                    </h1>
                    <p class="lead mb-5 fs-4">
                        Experience professional dental care in a comfortable educational environment.
                        Where patients meet future dental experts.
                    </p>
                    <div class="hero-buttons">
                        <a href="#about" class="btn btn-primary btn-lg me-3 px-4">
                            <i class="bi bi-info-circle me-2"></i>Learn More
                        </a>
                        <a href="#Services" class="btn btn-outline-light btn-lg px-4">
                            <i class="bi bi-stars me-2"></i>Our Services
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll Down Indicator -->
    <div class="scroll-indicator">
        <a href="#about">
            <i class="bi bi-chevron-double-down"></i>
        </a>
    </div>
</section>
<!-- How It Works Section -->
<section class="how-it-works py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-badge">Simple Process</span>
            <h2 class="section-title">
                How <span class="text-primary">It Works</span>
            </h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">
                Get started with our easy 3-step process
            </p>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="step-card text-center">
                    <div class="step-number">1</div>
                    <div class="step-icon">
                        <i class="bi bi-person-plus fs-1"></i>
                    </div>
                    <h5>Create Account</h5>
                    <p>Register with your basic information</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card text-center">
                    <div class="step-number">2</div>
                    <div class="step-icon">
                        <i class="bi bi-calendar-plus fs-1"></i>
                    </div>
                    <h5>Book Appointment</h5>
                    <p>Choose your preferred date and service</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card text-center">
                    <div class="step-number">3</div>
                    <div class="step-icon">
                        <i class="bi bi-emoji-smile fs-1"></i>
                    </div>
                    <h5>Get Treatment</h5>
                    <p>Visit clinic and receive professional care</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="about-section py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="about-image position-relative">
                    <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?w=600&h=400&fit=crop"
                         alt="Dental Clinic"
                         class="img-fluid rounded-4 shadow-lg">
                    <div class="about-experience-card">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-calendar-heart fs-1 text-primary me-3"></i>
                            <div>
                                <h3 class="mb-0 fw-bold">10+</h3>
                                <p class="mb-0">Years Experience</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about-content">
                    <span class="section-badge">About Us</span>
                    <h2 class="section-title mb-4">
                        Welcome to <span class="text-primary">Dental Clinic System</span>
                    </h2>
                    <p class="text-muted mb-4">
                        This innovative system helps improve communication and organize procedures between patients
                        and dental students within the teaching clinic. It allows patients to create personal accounts
                        and easily record their health condition and treatment needs.
                    </p>
                    <p class="text-muted mb-4">
                        Each case is evaluated by dental students under the direct supervision of experienced specialist doctors.
                        The system provides an effective way for the medical team and patients to communicate when needed.
                    </p>
                    <div class="row g-4 mb-4">
                        <div class="col-sm-6">
                            <div class="feature-list d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                <span>Professional Supervision</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-list d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                <span>Free Treatment</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-list d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                <span>Smart Scheduling</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-list d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                <span>Educational Environment</span>
                            </div>
                        </div>
                    </div>
                    <a href="#Services" class="btn btn-primary">
                        Explore Services <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="Services" class="services-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-badge">Our Services</span>
            <h2 class="section-title">
                Comprehensive <span class="text-primary">Dental Care</span>
            </h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">
                We offer a wide range of dental services to meet all your needs
            </p>
        </div>

        <div class="row g-4">
            <!-- Cosmetic Fillings -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Cosmetic Fillings">
                    <div class="service-icon">
                        <i class="bi bi-brush fs-1"></i>
                    </div>
                    <h4>Cosmetic Fillings</h4>
                    <p>Natural-looking restorations</p>
                </div>
            </div>

            <!-- Root Canal -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Root Canal">
                    <div class="service-icon">
                        <i class="bi bi-bandaid fs-1"></i>
                    </div>
                    <h4>Root Canal</h4>
                    <p>Save infected teeth</p>
                </div>
            </div>

            <!-- Cavities -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Cavities">
                    <div class="service-icon">
                        <i class="bi bi-eyedropper fs-1"></i>
                    </div>
                    <h4>Cavities</h4>
                    <p>Treat tooth decay</p>
                </div>
            </div>

            <!-- Teeth Cleaning -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Teeth Cleaning">
                    <div class="service-icon">
                        <i class="bi bi-droplet fs-1"></i>
                    </div>
                    <h4>Teeth Cleaning</h4>
                    <p>Remove tartar & plaque</p>
                </div>
            </div>

            <!-- Complete Dentures -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Complete Dentures">
                    <div class="service-icon">
                        <i class="bi bi-teeth fs-1"></i>
                    </div>
                    <h4>Complete Dentures</h4>
                    <p>Custom-fitted comfort</p>
                </div>
            </div>

            <!-- Teeth Whitening -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Teeth Whitening">
                    <div class="service-icon">
                        <i class="bi bi-stars fs-1"></i>
                    </div>
                    <h4>Teeth Whitening</h4>
                    <p>Brighten your smile</p>
                </div>
            </div>
        </div>

</section>

