﻿@{
ViewData["Title"] = "studint Dental Clinic System";
}

@section Styles {
    <link rel="stylesheet" href="~/css/index.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
}
@section Scripts {
    <script src="~/js/HomePage.js"></script>
}

<!-- Hero Section -->
<section id="home" class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container h-100 position-relative">
        <div class="row h-100 align-items-center">
            <div class="col-lg-8 mx-auto text-center text-white">
                <div class="hero-content">
                    <span class="hero-badge mb-3 d-inline-block">
                        <i class="bi bi-shield-heart me-1"></i>
                        <span data-key="badge">Professional Dental Care</span>
                    </span>

                    <h1 class="display-3 fw-bold mb-4">
                        <span data-key="title1">Your Smile,</span><br>
                        <span class="text-gradient" data-key="title2">Our Priority</span>
                    </h1>

                    <p class="lead mb-5 fs-4" data-key="desc">
                        Experience professional dental care in a comfortable educational environment.
                        Where patients meet future dental experts.
                    </p>


                    <a href="#about" class="btn btn-primary btn-lg me-3 px-4">
                        <i class="bi bi-info-circle me-2"></i>
                        <span data-key="learn">Learn More</span>
                    </a>

                    <a asp-controller="Home"
                       asp-action="Login"
                       class="btn btn-outline-light btn-lg px-4">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        <span data-key="login">Login</span>
                    </a>
                    
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll Down Indicator -->
    <div class="scroll-indicator">
        <a href="#about">
            <i class="bi bi-chevron-double-down"></i>
        </a>
    </div>
</section>
<!-- How It Works Section -->
<section class="how-it-works py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-badge" data-key="processBadge">Simple Process</span>
            <h2>
                <span data-key="how1">How</span>
                <span class="text-primary" data-key="how2">It Works</span>
            </h2>
            <p class="text-muted mx-auto" style="max-width: 600px;" data-key="howDesc">
                Get started with our easy 3-step process
            </p>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="step-card text-center">
                    <div class="step-number">1</div>
                    <div class="step-icon">
                        <i class="bi bi-person-plus fs-1"></i>
                    </div>
                    <h5 data-key="step1Title">Create Account</h5>
                    <p data-key="step1Desc">Register with your basic information</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card text-center">
                    <div class="step-number">2</div>
                    <div class="step-icon">
                        <i class="bi bi-calendar-plus fs-1"></i>
                    </div>
                    <h5 data-key="step2Title">Book Appointment</h5>
                    <p data-key="step2Desc">Choose your preferred date and service</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card text-center">
                    <div class="step-number">3</div>
                    <div class="step-icon">
                        <i class="bi bi-emoji-smile fs-1"></i>
                    </div>
                    <h5 data-key="step3Title">Get Treatment</h5>
                    <p data-key="step3Desc"> Visit clinic and receive professional care</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="about-section py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="about-image position-relative">
                    <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?w=600&h=400&fit=crop"
                         alt="Dental Clinic"
                         class="img-fluid rounded-4 shadow-lg">
                    <!--
                    <div class="about-experience-card">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-calendar-heart fs-1 text-primary me-3"></i>
                            
                            <div>
                                <h3 class="mb-0 fw-bold">10+</h3>
                                <p class="mb-0">Years Experience</p>
                            </div>
                            

                        </div
                    </div>-->
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about-content">
                    <span class="section-badge" data-key="aboutBadge">About Us</span>
                    <!-- العنوان -->
                    <h2>
                        <span data-key="aboutTitle1">Welcome to</span>
                        <span class="text-primary" data-key="aboutTitle2">Dental Clinic System</span>
                    </h2>
                    <p class="text-muted mb-4" data-key="aboutDesc1">
                        This innovative system helps improve communication and organize procedures between patients
                        and dental students within the teaching clinic. It allows patients to create personal accounts
                        and easily record their health condition and treatment needs.
                    </p>
                    <p class="text-muted mb-4" data-key="aboutDesc2">
                        Each case is evaluated by dental students under the direct supervision of experienced specialist doctors.
                        The system provides an effective way for the medical team and patients to communicate when needed.
                    </p>

                    <div class="row g-4 mb-4">

                        <div class="col-sm-6">
                            <div class="feature-list d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                <span data-key="feat1">Professional Supervision</span>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="feature-list d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                <span data-key="feat2">Free Treatment</span>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="feature-list d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                <span data-key="feat3">Smart Scheduling</span>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="feature-list d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                <span data-key="feat4">Educational Environment</span>
                            </div>
                        </div>

                    </div>

                    <a href="#Services" class="btn btn-primary">
                        <span data-key="explore">Explore Services</span>
                        <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="services-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-badge" data-key="servicesBadge">Our Services</span>
            <h2 class="section-title" data-key="servicesTitle1">
                Comprehensive <span class="text-primary" data-key="servicesTitle2">Dental Care</span>
            </h2>
            <p class="text-muted mx-auto" style="max-width: 600px;" data-key="servicesDesc">
                We offer a wide range of dental services to meet all your needs
            </p>
        </div>

        <div class="row g-4">
            <!-- Cosmetic Fillings -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Cosmetic Fillings" >
                    <div class="service-icon">
                        <i class="bi bi-brush fs-1"></i>
                    </div>
                    <h4 data-key="serv3Title">Cosmetic Fillings</h4>
                    <p data-key="serv3Desc">Natural-looking restorations</p>
                </div>
            </div>

            <!-- Root Canal -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Root Canal">
                    <div class="service-icon">
                        <i class="bi bi-bandaid fs-1"></i>
                    </div>
                    <h4 data-key="serv2Title">Root Canal</h4>
                    <p data-key="serv2Desc">Save infected teeth</p>
                </div>
            </div>

            <!-- Cavities -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Cavities">
                    <div class="service-icon">
                        <i class="bi bi-eyedropper fs-1"></i>
                    </div>
                    <h4 data-key="serv1Title">Cavities</h4>
                    <p data-key="serv1Desc">Treat tooth decay</p>
                </div>
            </div>

            <!-- Teeth Cleaning -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Teeth Cleaning">
                    <div class="service-icon">
                        <i class="bi bi-droplet fs-1"></i>
                    </div>
                    <h4 data-key="serv6Title">Teeth Cleaning</h4>
                    <p data-key="serv6Desc">Remove tartar & plaque</p>
                </div>
            </div>

            <!-- Complete Dentures -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Complete Dentures">
                    <div class="service-icon">
                        <i class="bi bi-teeth fs-1"></i>
                    </div>
                    <h4 data-key="serv5Title">Complete Dentures</h4>
                    <p data-key="serv5Desc">Custom-fitted comfort</p>
                </div>
            </div>

            <!-- Teeth Whitening -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card" data-service="Teeth Whitening">
                    <div class="service-icon">
                        <i class="bi bi-stars fs-1"></i>
                    </div>
                    <h4 data-key="serv4Title">Teeth Whitening</h4>
                    <p data-key="serv4Desc">Brighten your smile</p>
                </div>
            </div>
        </div>

</section>

<!-- Feedback Section -->
<section id="feedback" class="feedback-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-badge" data-key="testiBadge">Testimonials</span>
            <h2 class="section-title" data-key="testiTitle1">
                What Our <span class="text-primary" data-key="testiTitle2">Patients Say</span>
            </h2>
            <p class="text-muted mx-auto" style="max-width: 600px;" data-key="testiDesc">
                Real experiences from people who trusted us with their smile
            </p>
        </div>

        <div id="feedbackCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <!-- Slide 1 -->
                <div class="carousel-item active">
                    <div class="row g-4 justify-content-center">
                        <div class="col-md-4">
                            <div class="feedback-card">
                                <div class="feedback-quote">
                                    <i class="bi bi-quote"></i>
                                </div>
                                <div class="feedback-content">
                                    <p>Excellent service and professional doctor. The clinic is very clean and organized.</p>
                                </div>
                                <div class="feedback-author">
                                    <img src="https://i.pravatar.cc/120?img=1" alt="Ahmad" class="feedback-img">
                                    <div>
                                        <h6 class="mb-0">Ahmad Ali</h6>
                                        <div class="text-warning small">★★★★★</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="feedback-card">
                                <div class="feedback-quote">
                                    <i class="bi bi-quote"></i>
                                </div>
                                <div class="feedback-content">
                                    <p>Amazing experience! The students were very professional and the doctors supervised everything.</p>
                                </div>
                                <div class="feedback-author">
                                    <img src="https://i.pravatar.cc/120?img=5" alt="Sara" class="feedback-img">
                                    <div>
                                        <h6 class="mb-0">Sara Mohammad</h6>
                                        <div class="text-warning small">★★★★★</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="feedback-card">
                                <div class="feedback-quote">
                                    <i class="bi bi-quote"></i>
                                </div>
                                <div class="feedback-content">
                                    <p>Fast appointment booking and very friendly staff. Highly recommended!</p>
                                </div>
                                <div class="feedback-author">
                                    <img src="https://i.pravatar.cc/120?img=12" alt="Omar" class="feedback-img">
                                    <div>
                                        <h6 class="mb-0">Omar Khaled</h6>
                                        <div class="text-warning small">★★★★★</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Slide 2 -->
                <div class="carousel-item">
                    <div class="row g-4 justify-content-center">
                        <div class="col-md-4">
                            <div class="feedback-card">
                                <div class="feedback-quote">
                                    <i class="bi bi-quote"></i>
                                </div>
                                <div class="feedback-content">
                                    <p>Very gentle treatment. I was nervous but they made me feel comfortable.</p>
                                </div>
                                <div class="feedback-author">
                                    <img src="https://i.pravatar.cc/120?img=20" alt="Lina" class="feedback-img">
                                    <div>
                                        <h6 class="mb-0">Lina Hassan</h6>
                                        <div class="text-warning small">★★★★★</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="feedback-card">
                                <div class="feedback-quote">
                                    <i class="bi bi-quote"></i>
                                </div>
                                <div class="feedback-content">
                                    <p>Best dental clinic ever! The system is easy to use and very efficient.</p>
                                </div>
                                <div class="feedback-author">
                                    <img src="https://i.pravatar.cc/120?img=25" alt="Mohammad" class="feedback-img">
                                    <div>
                                        <h6 class="mb-0">Mohammad Saleh</h6>
                                        <div class="text-warning small">★★★★★</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="feedback-card">
                                <div class="feedback-quote">
                                    <i class="bi bi-quote"></i>
                                </div>
                                <div class="feedback-content">
                                    <p>Free treatment with professional supervision - what more could you ask for?</p>
                                </div>
                                <div class="feedback-author">
                                    <img src="https://i.pravatar.cc/120?img=30" alt="Noor" class="feedback-img">
                                    <div>
                                        <h6 class="mb-0">Noor Ahmad</h6>
                                        <div class="text-warning small">★★★★★</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#feedbackCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#feedbackCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
</section>
<!-- Service Modal -->
<div class="modal fade" id="serviceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Service Name</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-4">
                <div id="modalIcon" class="mb-4"></div>
                <p id="modalDescription" class="lead mb-4"></p>
                <div id="modalDetails" class="text-start bg-light p-3 rounded-3"></div>
            </div>
           
        </div>
    </div>
</div>
<!-- Why Choose Us Section -->
<section class="why-choose-us py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-badge" data-key="whyBadge">Why Choose Us</span>
            <h2 class="section-title" data-key="whyTitle1">
                Why <span class="text-primary" data-key="whyTitle2">Dental Clinic</span>
            </h2>
            <p class="text-muted mx-auto" style="max-width: 600px;" data-key="whyDesc">
                We provide the best dental care with professional supervision
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="why-card text-center">
                    <div class="why-icon">
                        <i class="bi bi-person-badge fs-1"></i>
                    </div>
                    <h5 data-key="why4Title">Expert Doctors</h5>
                    <p data-key="why4Desc">Supervised by experienced specialist doctors</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="why-card text-center">
                    <div class="why-icon">
                        <i class="bi bi-cash-stack fs-1"></i>
                    </div>
                    <h5 data-key="why3Title">Free Treatment</h5>
                    <p data-key="why3Desc">Quality dental care at no cost</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="why-card text-center">
                    <div class="why-icon">
                        <i class="bi bi-calendar-check fs-1"></i>
                    </div>
                    <h5 data-key="why2Title">Easy Booking</h5>
                    <p data-key="why2Desc">Simple appointment scheduling system</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="why-card text-center">
                    <div class="why-icon">
                        <i class="bi bi-shield-check fs-1"></i>
                    </div>
                    <h5 data-key="why1Title">Safe & Clean</h5>
                    <p data-key="why1Desc">Sterilized equipment and safe environment</p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Statistics Section -->
<section class="stats-section py-5">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-3 col-6">
                <div class="stat-card">
                    <i class="bi bi-people-fill fs-1 text-primary"></i>
                    <h2 class="counter fw-bold mt-2" data-target="5000">0</h2>
                    <p class="text-muted" data-key="stat4">Happy Patients</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-card">
                    <i class="bi bi-calendar-check-fill fs-1 text-primary"></i>
                    <h2 class="counter fw-bold mt-2" data-target="12000">0</h2>
                    <p class="text-muted" data-key="stat3">Appointments</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-card">
                    <i class="bi bi-hospital-fill fs-1 text-primary"></i>
                    <h2 class="counter fw-bold mt-2" data-target="25">0</h2>
                    <p class="text-muted" data-key="stat2">Expert Doctors</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-card">
                    <i class="bi bi-star-fill fs-1 text-primary"></i>
                    <h2 class="counter fw-bold mt-2" data-target="98">0</h2>
                    <p class="text-muted" data-key="stat1">Satisfaction %</p>
                </div>
            </div>
        </div>
    </div>
</section>
<button id="backToTop" class="back-to-top">
    <i class="bi bi-arrow-up"></i>
</button>




