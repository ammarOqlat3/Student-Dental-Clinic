
﻿@{
    ViewData["Title"] = "loginPage";
}
@section Styles {
    <link rel="stylesheet" href="~/css/loginPage.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
}
@section Scripts {
    <script src="~/js/loginPage.js"></script>
}

<div class="login-page-wrapper">
    <div class="container-box" id="container">
        <div class="form-box register-container">
            <form action="#">
                <h3 class="title mb-4" data-key="register">Create Account</h3>
                <input type="text" class="form-control custom-input mb-3" placeholder="Username" data-key-placeholder="username">
                <input type="email" class="form-control custom-input mb-3" placeholder="Email" data-key-placeholder="email">
                <input type="password" class="form-control custom-input mb-3" placeholder="Password" data-key-placeholder="password">
                <button type="button" class="btn btn-success-glass w-100 py-2 mt-2">Register</button>
            </form>
        </div>

        <div class="form-box login-container">
            <form asp-controller="LogIn" asp-action="Index" method="get">
                <h3 class="title mb-4" data-key="login">Welcome Back</h3>
                <input type="text" class="form-control custom-input mb-3" placeholder="Username" data-key-placeholder="username">
                <input type="password" class="form-control custom-input mb-3" placeholder="Password" data-key-placeholder="password">

                <div class="options mb-4">
                    <label class="remember-me">
                        <input type="checkbox"> <span data-key="remember">Remember me</span>
                    </label>
                    <a href="#" class="forgot-link" data-key="forgot">Forgot password?</a>
                </div>
                <button type="submit" class="btn btn-primary-glass w-100 py-2">Login</button>
            </form>
        </div>

        <div class="overlay-container">
            <div class="overlay">
                <div class="overlay-panel overlay-left">
                    <h2 class="fw-bold">Already Member?</h2>
                    <p>Login to keep track of your clinic appointments</p>
                    <button class="ghost-btn" id="goLogin">Login</button>
                </div>
                <div class="overlay-panel overlay-right">
                    <h2 class="fw-bold">New Patient?</h2>
                    <p>Register now to get the best professional medical care</p>
                    <button class="ghost-btn" id="goRegister">Register</button>
                </div>
            </div>
        </div>
    </div>
</div>
<br />
<br />
<div>




    <a asp-controller="LogIn" asp-action="Students"
       class="btn btn-outline-light btn-lg px-4 text-black text-center">
       
       Students
    </a>




</div>

