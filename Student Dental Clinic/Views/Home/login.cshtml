@section Scripts {
    <script src="~/js/loginPage.js" asp-append-version="true"></script>
}

<div class="login-page-wrapper">
    <div class="container-box" id="container">
        <div class="form-box register-container">
            <form asp-controller="Home" asp-action="Register" method="post">
                <h3 class="title mb-4" data-key="register">Create Account</h3>
                <input type="text" name="Username" class="form-control custom-input mb-3" placeholder="Username" data-key-placeholder="username">
                <input type="email" name="Email" class="form-control custom-input mb-3" placeholder="Email" data-key-placeholder="email">
                <input type="password" name="Password" class="form-control custom-input mb-3" placeholder="Password" data-key-placeholder="password">
                <button type="submit" class="btn btn-success-glass w-100 py-2 mt-2" data-key="registerBtn">Register</button>
            </form>
        </div>

        <div class="form-box login-container">
            <form asp-controller="Home" asp-action="login" method="post">
                <h3 class="title mb-4" data-key="welcomeBack">Welcome Back</h3>
                <input type="text" name="Username" class="form-control custom-input mb-3" placeholder="Username" data-key-placeholder="username">
                <input type="password" name="Password" class="form-control custom-input mb-3" placeholder="Password" data-key-placeholder="password">

                <div class="options mb-4">
                    <label class="remember-me">
                        <input type="checkbox"> <span data-key="remember">Remember me</span>
                    </label>
                    <a href="#" class="forgot-link" data-key="forgot">Forgot password?</a>
                </div>
                <button type="submit" class="btn btn-primary-glass w-100 py-2" data-key="loginBtn">Login</button>
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Success"]
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["Error"]
                    </div>
                }
            </form>
        </div>

        <div class="overlay-container">
            <div class="overlay">
                <div class="overlay-panel overlay-left">
                    <h2 class="fw-bold" data-key="haveAccount">Already Member?</h2>
                    <p data-key="haveAccountDesc">Login to keep track of your clinic appointments</p>
                    <button class="ghost-btn" id="goLogin" data-key="loginBtn">Login</button>
                </div>
                <div class="overlay-panel overlay-right">
                    <h2 class="fw-bold" data-key="noAccount">New Patient?</h2>
                    <p data-key="noAccountDesc">Register now to get the best professional medical care</p>
                    <button class="ghost-btn" id="goRegister" data-key="registerBtn">Register</button>
                </div>
            </div>
        </div>
    </div>
</div>
<br />
<br />
<div>
    <a asp-controller="LogIn" asp-action="Students"
       class="btn btn-outline-light btn-lg px-4 text-black text-center">
        Students
    </a>
    <a asp-controller="LogIn" asp-action="doctor"
       class="btn btn-outline-light btn-lg px-4 text-black text-center">
        doctor
    </a>
</div>