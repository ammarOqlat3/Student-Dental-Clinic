@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dental Clinic System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    @RenderSection("Styles", required: false)

    
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg shadow-sm px-lg-5">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/" data-key="title">Studint Dental Clinic</a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto text-center">
                        <li class="nav-item"><a class="nav-link" href="/#home" data-key="home">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#about" data-key="about">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#services" data-key="service">Service</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#feedback" data-key="feedback">Feedback</a></li>
                    </ul>

                    <div class="nav-actions d-flex align-items-center justify-content-center" style="gap: 15px;">
                        <button id="darkModeToggle" style="border:none; background:none; cursor:pointer; font-size:1.2rem;">🌙</button>

                        <div class="lang-container">
                            <button class="btn btn-outline-primary btn-sm" id="langBtnToggle" onclick="toggleLangMenu(event)">
                                🌐 <span id="currentLangDisplay">English</span> <small>▼</small>
                            </button>
                            <div id="langMenuBox" class="lang-menu">
                                <div onclick="changeLang('ar', event)">العربية</div>

                                <div onclick="changeLang('en', event)">English</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="footer-widget">
                        <h3 class="footer-logo" data-key="footerLogo">Dental<span>Clinic</span></h3>     
                        <p class="opacity-75" data-key="clinicDesc">
                            Providing quality dental care while supporting future dental professionals.
                        </p>
                        <div class="social-links">
                            <a href="#"><i class="bi bi-facebook"></i></a>
                            <a href="#"><i class="bi bi-twitter-x"></i></a>
                            <a href="#"><i class="bi bi-instagram"></i></a>
                            <a href="#"><i class="bi bi-linkedin"></i></a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h5 data-key="quickLinks">Quick Links</h5>
                    <ul class="footer-links">
                        <li><a href="#" data-key="home">Home</a></li>
                        <li><a href="#about" data-key="about">About</a></li>
                        <li><a href="#Services" data-key="service">Services</a></li>
                        <li><a href="#Feedback" data-key="feedback">Feedback</a></li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h5 data-key="footerServices">Services</h5>
                    <ul class="footer-links">
                        <li><a href="#" data-key="filling">Fillings</a></li>
                        <li><a href="#" data-key="root">Root Canal</a></li>
                        <li><a href="#" data-key="white">Whitening</a></li>
                        <li><a href="#" data-key="dentures">Dentures</a></li>
                    </ul>
                </div>

                <div class="col-lg-4">
                    <h5 data-key="contactTitle">Contact Info</h5>
                    <ul class="footer-links">
                        <li><i class="bi bi-geo-alt me-2"></i><span data-key="location">Amman, Jordan</span></li>
                        <li><i class="bi bi-envelope me-2"></i><span data-key="email">info@dentalclinic.com</span></li>
                        <li><i class="bi bi-telephone me-2"></i><span data-key="phone">+962 7 1234 5678</span></li>
                    </ul>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12 text-center">
                    <hr style="border-color: var(--footer-border)">
                    <p class="mb-3 opacity-75" data-key="copyright">© 2026 Dental Clinic System</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/lang.js"></script>

    <script>
        // 1. Dark Mode Logic
        const themeToggle = document.getElementById('darkModeToggle');
        function applyTheme(theme) {
            document.documentElement.setAttribute('data-bs-theme', theme);
            localStorage.setItem('theme', theme);
            themeToggle.textContent = (theme === 'dark') ? '☀️' : '🌙';
        }
        const savedTheme = localStorage.getItem('theme') || 'light';
        applyTheme(savedTheme);
        themeToggle.onclick = () => {
            const currentTheme = document.documentElement.getAttribute('data-bs-theme');
            applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
        };

        // 2. Language Menu Logic
        /*
        const langBtn = document.getElementById('langBtnToggle');
        const langMenu = document.getElementById('langMenuBox');

        langBtn.onclick = (e) => {
            e.stopPropagation();
            langMenu.style.display = (langMenu.style.display === 'flex') ? 'none' : 'flex';
        };

        window.onclick = () => {
            langMenu.style.display = 'none';
        };

        function changeLanguage(lang) {
            if (typeof changeLang === "function") {
                changeLang(lang);
            }
            document.getElementById('currentLangDisplay').textContent = (lang === 'ar') ? 'العربية' : 'English';
        }*/
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>