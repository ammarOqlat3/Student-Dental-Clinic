@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dental Clinic System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Task1_Part2.styles.css" asp-append-version="true" />



    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    @RenderSection("Styles", required: false)

    <style>
        :root {
            --bg-color: #ffffff;
            --text-color: #212529;
            --card-bg: #ffffff;
            --navbar-bg: #f8f9fa;
            --footer-bg: #1a1e2c;
            --footer-text: #ffffff;
        }

        [data-bs-theme="dark"] {
            --bg-color: #121212;
            --text-color: #f8f9fa;
            --card-bg: #1e1e2e;
            --navbar-bg: #0a0c15;
            --footer-bg: #050507;
            --footer-text: #f8f9fa;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            transition: 0.3s;
            font-family: 'Poppins', sans-serif;
        }

        .navbar {
            background-color: var(--navbar-bg) !important;
        }

            .navbar .nav-link,
            .navbar .navbar-brand {
                color: var(--text-color) !important;
            }
    </style>
</head>
<script src="~/js/lang.js"></script>


<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm px-5">

            <a class="navbar-brand fw-bold" id="siteTitle">Dental Clinic</a>

            <!-- ✅ FIXED (Bootstrap 5) -->
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">
                <i class="fas fa-bars fs-3"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto text-center">
                    <li class="nav-item">
                        <a class="nav-link" id="navHome" href="/#home">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="navAbout" href="/#about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="navService" href="/#services">Service</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="navFeedback" href="/#feedback">Feedback</a>
                    </li>
                </ul>
                <div class="nav-actions d-flex align-items-center">
                    <button id="darkModeToggle" class="btn">🌙</button>
                    <div class="lang-container">
                        <button class="lang-btn" onclick="toggleLangMenu()">
                            🌐 <span id="currentLang">English</span>
                            <span class="arrow">▼</span>
                        </button>

                        <div id="langMenu" class="lang-menu">
                            <div onclick="changeLang('en', event)">English</div>
                            <div onclick="changeLang('ar', event)">العربية</div>
                        </div>
                    </div>
                 
                </div>

            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <!-- ❌ حذف Bootstrap 4 -->
    <!-- ✅ Bootstrap 5 -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


    @await RenderSectionAsync("Scripts", required: false)

    <script>
        function setDarkMode(isDark) {
            document.documentElement.setAttribute('data-bs-theme', isDark ? 'dark' : 'light');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            document.getElementById('darkModeToggle').textContent = isDark ? '☀️' : '🌙';
        }

        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') setDarkMode(true);

        document.getElementById('darkModeToggle').onclick = () => {
            const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            setDarkMode(!isDark);
        };
    </script>

</body>
</html>