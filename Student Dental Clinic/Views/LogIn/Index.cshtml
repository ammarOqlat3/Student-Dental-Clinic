@{
    ViewData["Title"] = "info Patient ";
}
@section Styles {
    <link rel="stylesheet" href="~/css/infoPatient.css" />
}
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/infoPatient.js"></script>

}

<div class="container py-5">
    <div class="dashboard-header p-4 mb-4 shadow-lg text-white d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
            <div class="profile-pic-container me-3">
                <img src="https://ui-avatars.com/api/?name=Patient+User&background=0d6efd&color=fff" id="navProfilePic" class="rounded-circle border border-3 border-white shadow" width="60">
                <i class="fas fa-camera upload-icon"></i>
            </div>
            <div>
                <h4 class="fw-bold mb-0">Welcome back, <span id="userNameDisplay">Patient</span></h4>
                <p class="small mb-0 opacity-75">Member since: April 2026</p>
            </div>
        </div>
        <div class="nav-pills-container">
            <ul class="nav nav-pills custom-pills" id="pills-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#pills-new" type="button">New Request</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="pill" data-bs-target="#pills-history" type="button">My Cases</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="pill" data-bs-target="#pills-profile" type="button">Profile</button>
                </li>
            </ul>
        </div>
    </div>

    <div class="tab-content" id="pills-tabContent">
        <div class="tab-pane fade show active" id="pills-new">
            <div class="welcome-section p-5 text-center mb-4 shadow-lg">
                <h2 class="fw-bold mb-4">Welcome to Our Clinicy</h2>
                <p class="lead opacity-75">Thank you for your trust. We promise you a pleasant and professional experience.</p>
                <button class="btn btn-primary btn-lg mt-3 px-5 shadow-sm" id="startBtn">Click here to fill in your information</button>
            </div>

            @* <div class="tab-pane fade show active" id="pills-new">
                <div class="welcome-section p-5 text-center mb-4 shadow-lg">
                    <h2 class="fw-bold mb-4">Welcome to Our Clinic</h2>
                    <p class="lead opacity-75">Thank you for your trust. We promise you a pleasant and professional experience.</p>
                    <button class="btn btn-primary btn-lg mt-3 px-5 shadow-sm" id="startBtn">Click here to fill in your information</button>
                </div> *@

                <div id="patientFormSection" class="form-container p-4 shadow-lg">
                    <h4 class="mb-4 text-center border-bottom pb-3 text-white">Patient Information Form</h4>

                    <form asp-action="Create" asp-controller="Patients" method="post" enctype="multipart/form-data" id="patientForm">
                        <div class="row g-4">

                            <div class="col-md-4">
                                <label class="form-label fw-bold">First Name</label>
                                <input class="form-control" name="FirstName" placeholder="First Name" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Middle Name</label>
                                <input class="form-control" name="MiddleName" placeholder="Middle Name" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Last Name</label>
                                <input class="form-control" name="LastName" placeholder="Last Name" required />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Age</label>
                                <input type="number" class="form-control" name="Age" placeholder="Age" required />
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Email Address</label>
                                <input type="email" class="form-control" name="Email" placeholder="example@mail.com" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Phone Number</label>
                                <input type="tel" class="form-control" name="PhoneNumber" placeholder="07XXXXXXXX" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Gender</label>
                                <select class="form-select" name="Gender" required>
                                    <option value="">Select Gender...</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">Do you suffer from any chronic diseases or allergies?</label>
                                <div class="mt-2">
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="hasAllergy" id="yesRadio" value="yes">
                                        <label class="form-check-label" for="yesRadio">Yes</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="hasAllergy" id="noRadio" value="no" checked>
                                        <label class="form-check-label" for="noRadio">No</label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-12 d-none" id="allergyDetailsBox">
                                <label class="form-label fw-bold text-danger">Please provide details:</label>
                                <textarea class="form-control" name="AllergyDetails" rows="3" placeholder="Describe your condition here..."></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Type of Treatment</label>
                                <select class="form-select" name="TreatmentType" required>
                                    <option value="">Select treatment...</option>
                                    <option value="CosmeticFilling">Cosmetic Filling</option>
                                    <option value="RootCanal">Root Canal</option>
                                    <option value="Cleaning">Teeth Cleaning</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Upload Tooth Photo</label>
                                <input type="file" name="ToothImage" class="form-control" accept="image/*" />
                            </div>

                            <div class="col-12 mt-5">
                                <button type="submit" class="btn btn-success btn-lg w-100 py-3 shadow">Submit Request</button>
                            </div>
                        </div>
                    </form>
                </div>
</div>


        <div class="tab-pane fade" id="pills-history">
            <div class="glass-card p-4 shadow-lg">
                <h4 class="mb-4 border-bottom pb-3"><i class="fas fa-history me-2"></i>My Medical History</h4>
                <div class="table-responsive">
                    <table class="table table-hover custom-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Treatment</th>
                                <th>Doctor</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>20/03/2026</td>
                                <td>Root Canal</td>
                                <td>Dr. Sami</td>
                                <td><span class="badge bg-warning">Pending</span></td>
                                <td><button class="btn btn-sm btn-outline-light">View Details</button></td>
                            </tr>
                            <tr>
                                <td>15/01/2026</td>
                                <td>Teeth Cleaning</td>
                                <td>Dr. Layla</td>
                                <td><span class="badge bg-success">Completed</span></td>
                                <td><button class="btn btn-sm btn-outline-light">View Details</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="pills-profile">
            <div class="glass-card p-4 shadow-lg">
                <div class="row">
                    <div class="col-md-4 text-center border-end border-secondary">
                        <div class="profile-avatar-large mb-3">
                            <img src="https://ui-avatars.com/api/?name=Patient+User&size=150" class="rounded-circle shadow">
                        </div>
                        <button class="btn btn-outline-primary btn-sm mb-3">Change Photo</button>
                    </div>
                    <div class="col-md-8">
                        <h4 class="mb-4">Account Settings</h4>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small opacity-75">Full Name</label>
                                <p class="fw-bold">Patient User Name</p>
                            </div>
                            <div class="col-md-6">
                                <label class="small opacity-75">Email</label>
                                <p class="fw-bold">patient@example.com</p>
                            </div>
                            <div class="col-md-6">
                                <label class="small opacity-75">Phone</label>
                                <p class="fw-bold">07XXXXXXXX</p>
                            </div>
                            <div class="col-12 mt-4">
                                <button class="btn btn-primary">Update Profile Info</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>