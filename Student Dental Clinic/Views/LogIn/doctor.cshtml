@using System.Text.Json
@{
    var _reports = (ViewBag.Reports as List<Student_Dental_Clinic.Models.Report>) ?? new();
    var _patients = (Model as List<Student_Dental_Clinic.Models.Patient>) ?? new();
    var _students = (ViewBag.Students as List<Student_Dental_Clinic.Models.Student>) ?? new();

    // ── build reports JSON ──────────────────────────────────────────────
    var rList = new System.Text.StringBuilder();
    rList.Append('[');
    for (int ri = 0; ri < _reports.Count; ri++)
    {
        var r = _reports[ri];
        if (ri > 0) rList.Append(',');
        rList.Append('{');
        rList.Append($"\"id\":{r.Id},");
        rList.Append($"\"student\":{JsonSerializer.Serialize(r.Student?.FullName ?? "")},");
        rList.Append($"\"studentId\":{r.StudentId},");
        var patName = ((r.Case?.Patient?.FirstName ?? "") + " " + (r.Case?.Patient?.LastName ?? "")).Trim();
        rList.Append($"\"patient\":{JsonSerializer.Serialize(patName)},");
        rList.Append($"\"caseType\":{JsonSerializer.Serialize(r.Case?.TreatmentType ?? "")},");
        rList.Append($"\"caseId\":{r.CaseId},");
        rList.Append($"\"date\":{JsonSerializer.Serialize(r.SubmittedAt.ToString("MMM dd, yyyy"))},");
        rList.Append($"\"chiefComplaint\":{JsonSerializer.Serialize(r.ChiefComplaint)},");
        rList.Append($"\"diagnosisNotes\":{JsonSerializer.Serialize(r.DiagnosisNotes)},");
        rList.Append($"\"treatmentDone\":{JsonSerializer.Serialize(r.TreatmentDone)},");
        rList.Append($"\"followUpPlan\":{JsonSerializer.Serialize(r.FollowUpPlan)},");
        rList.Append($"\"complications\":{JsonSerializer.Serialize(r.Complications)},");
        rList.Append($"\"content\":{JsonSerializer.Serialize(r.Content)},");
        rList.Append($"\"beforeImage\":{JsonSerializer.Serialize(r.BeforeImagePath)},");
        rList.Append($"\"afterImage\":{JsonSerializer.Serialize(r.AfterImagePath)},");
        rList.Append($"\"grade\":{(r.Rating.HasValue ? r.Rating.Value.ToString() : "null")},");
        rList.Append($"\"maxGrade\":{(r.MaxGrade.HasValue ? r.MaxGrade.Value.ToString() : "10")},");
        rList.Append($"\"feedback\":{JsonSerializer.Serialize(r.DoctorFeedback)},");
        rList.Append($"\"status\":{JsonSerializer.Serialize(r.Rating.HasValue ? "graded" : "pending")}");
        rList.Append('}');
    }
    rList.Append(']');

    // ── build patients JSON ─────────────────────────────────────────────
    var pList = new System.Text.StringBuilder();
    pList.Append('[');
    for (int pi = 0; pi < _patients.Count; pi++)
    {
        var p = _patients[pi];
        if (pi > 0) pList.Append(',');
        pList.Append('{');
        var pName = ((p.FirstName ?? "") + " " + (p.LastName ?? "")).Trim();
        pList.Append($"\"id\":{p.Id},");
        pList.Append($"\"name\":{JsonSerializer.Serialize(pName)},");
        pList.Append($"\"age\":{p.Age},");
        pList.Append($"\"gender\":{JsonSerializer.Serialize(p.Gender ?? "")},");
        pList.Append($"\"phone\":{JsonSerializer.Serialize(p.PhoneNumber ?? "")},");
        pList.Append($"\"case\":{JsonSerializer.Serialize(p.TreatmentType ?? "")},");
        pList.Append($"\"date\":{JsonSerializer.Serialize(p.CreatedAt.ToString("MMM dd, yyyy"))},");
        pList.Append($"\"status\":{JsonSerializer.Serialize((p.Status ?? "pending").ToLower())},");
        pList.Append($"\"student\":{JsonSerializer.Serialize(p.Student?.FullName ?? "")}");
        pList.Append('}');
    }
    pList.Append(']');

    // ── build students JSON ─────────────────────────────────────────────
    var sList = new System.Text.StringBuilder();
    sList.Append('[');
    for (int si = 0; si < _students.Count; si++)
    {
        var s = _students[si];
        if (si > 0) sList.Append(',');
        var sCases = s.Cases?.ToList() ?? new List<Student_Dental_Clinic.Models.Case>();
        var sGraded = _reports.Where(rp => rp.StudentId == s.Id && rp.Rating.HasValue).ToList();
        var sAvg = sGraded.Any() ? Math.Round(sGraded.Average(rp => (double)rp.Rating!.Value), 1) : (double?)null;

        var casesArr = new System.Text.StringBuilder();
        casesArr.Append('[');
        for (int ci = 0; ci < sCases.Count; ci++)
        {
            if (ci > 0) casesArr.Append(',');
            var cLabel = (sCases[ci].TreatmentType ?? "") + " - " +
                         (sCases[ci].Patient?.FirstName ?? "") + " " +
                         (sCases[ci].Patient?.LastName ?? "");
            casesArr.Append(JsonSerializer.Serialize(cLabel));
        }
        casesArr.Append(']');

        sList.Append('{');
        sList.Append($"\"id\":{s.Id},");
        sList.Append($"\"name\":{JsonSerializer.Serialize(s.FullName ?? "")},");
        sList.Append($"\"number\":{JsonSerializer.Serialize(s.UniversityId ?? "")},");
        sList.Append($"\"email\":{JsonSerializer.Serialize(s.Email ?? "")},");
        sList.Append($"\"phone\":{JsonSerializer.Serialize(s.PhoneNumber ?? "")},");
        sList.Append($"\"year\":{JsonSerializer.Serialize(s.AcademicYear ?? "")},");
        sList.Append($"\"casesCount\":{sCases.Count},");
        sList.Append($"\"graded\":{sGraded.Count},");
        sList.Append($"\"avg\":{(sAvg.HasValue ? sAvg.Value.ToString() : "null")},");
        sList.Append($"\"cases\":{casesArr}");
        sList.Append('}');
    }
    sList.Append(']');
}

<script id="dbReportsData" type="application/json">@Html.Raw(rList.ToString())</script>
<script id="dbPatientsData" type="application/json">@Html.Raw(pList.ToString())</script>
<script id="dbStudentsData" type="application/json">@Html.Raw(sList.ToString())</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
