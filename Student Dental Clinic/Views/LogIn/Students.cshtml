<div class="container py-5" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-primary" data-key="studentTitle">Clinical Cases Platform</h2>
            <p class="text-muted" data-key="studentSubtitle">Browse and book available training cases</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-5 filter-card">
        <div class="card-body">
            <div class="row g-3">

                <div class="col-md-4">
                    <label data-key="caseType">Case Type</label>
                    <select id="typeFilter" class="form-select">
                        <option value="all" data-key="allCases">All Cases</option>
                        <option value="حشوة" data-key="filling">Filling</option>
                        <option value="سحب عصب" data-key="rootCanal">Root Canal</option>
                        <option value="تقويم" data-key="orthodontics">Orthodontics</option>
                        <option value="تنظيف" data-key="scaling">Scaling</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label data-key="ageGroup">Age Group</label>
                    <select id="ageFilter" class="form-select">
                        <option value="الكل" data-key="allAges">All Ages</option>
                        <option value="20-25" data-key="age1">20-25</option>
                        <option value="26-30" data-key="age2">26-30</option>
                        <option value="31-40" data-key="age3">31-40</option>
                    </select>
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-primary w-100" onclick="executeFilter()">
                        <span data-key="updateResults">Update Results</span>
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- مهم: row -->
    <div class="row" id="patientsGrid"></div>
</div>

<style>
    /* الإعدادات العامة */
    body {
        font-family: 'Cairo', sans-serif;
        margin: 0;
        transition: all 0.3s ease;
    }

        /* التحكم بالاتجاه بناءً على الكلاس اللي بضيفه الـ JS */
        body.rtl {
            direction: rtl;
            text-align: right;
        }

        body.ltr {
            direction: ltr;
            text-align: left;
        }

    /* حل مشكلة الهيدر (Header/Navbar) */
    /* افترضنا أن الكلاس اسمه navbar أو header */
    .header-container {
        display: flex;
        align-items: center;
        justify-content: space-between; /* هذا سيجعل اللوجو في طرف والقائمة في طرف تلقائياً */
        padding: 10px 5%;
    }

    /* القائمة داخل الهيدر */
    .nav-links {
        display: flex;
        gap: 20px;
        list-style: none;
        /* نستخدم margin-inline-start بدلاً من margin-left */
        margin-inline-start: auto;
    }

    /* العلامة الخضراء (Status Badge) */
    .status-badge {
        position: absolute;
        top: 15px;
        /* سحر الـ Logical Properties */
        inset-inline-start: 15px;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
    }

    /* البطاقة (Card) */
    .card {
        border-radius: 15px;
        position: relative;
    }

    /* أي أيقونات أو عناصر داخلية يفضل تستخدم لها */
    .icon {
        margin-inline-end: 10px; /* تعطي مسافة بعد الأيقونة حسب اللغة */
    }

    /* لضمان عدم تفكك الحروف */
    * {
        letter-spacing: normal !important;
    }
</style>
<script>
    let patients = [
        { id: 1, name: "أحمد العلي", age: 22, type: "حشوة", gender: "ذكر", phone: "0791234567", email: "ahmed@mail.com", address: "عمان", status: "متاح" },
        { id: 2, name: "سارة حسن", age: 28, type: "سحب عصب", gender: "أنثى", phone: "0785554433", email: "sara@mail.com", address: "إربد", status: "متاح" },
        { id: 3, name: "محمد خالد", age: 35, type: "تقويم", gender: "ذكر", phone: "0770001122", email: "mhd@mail.com", address: "الزرقاء", status: "متاح" }
    ];

    function renderPatients(data) {
        const grid = document.getElementById('patientsGrid');
        grid.innerHTML = '';

        data.forEach(p => {
            const statusClass = p.status === 'متاح' ? 'bg-available' : 'bg-booked';

            grid.innerHTML += `
            <div class="col-md-4 mb-4">
                <div class="card patient-card p-3 position-relative" onclick="openDetails(${p.id})">

                    <span class="status-badge ${statusClass}">${p.status}</span>

                    <div class="text-center">
                        <img src="https://ui-avatars.com/api/?name=${p.name}&background=random"
                             class="rounded-circle mb-3" width="80">

                        <h5 class="fw-bold">${p.name}</h5>

                        <span class="badge bg-light text-primary border">${p.type}</span>

                        <div class="small text-muted mt-2">
                            العمر: ${p.age} سنة | السكن: ${p.address}
                        </div>
                    </div>

                </div>
            </div>
            `;
        });
    }

    function executeFilter() {
        const type = document.getElementById('typeFilter').value;
        const ageRange = document.getElementById('ageFilter').value;

        const filtered = patients.filter(p => {
            const matchType = (type === 'all' || p.type === type);

            let matchAge = true;
            if (ageRange === '20-25') matchAge = (p.age >= 20 && p.age <= 25);
            else if (ageRange === '26-30') matchAge = (p.age >= 26 && p.age <= 30);
            else if (ageRange === '31-40') matchAge = (p.age >= 31 && p.age <= 40);

            return matchType && matchAge;
        });

        renderPatients(filtered);
    }

    renderPatients(patients);
</script>