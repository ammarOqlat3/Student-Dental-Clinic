                </div>
            </aside>
            <!-- /SIDEBAR -->
            <!-- ==================== MAIN ==================== -->
            <div class="st-main">

                <!-- التوبار -->
                <div class="st-topbar">
                    <div class="pg-title" id="stPageTitle">لوحتي</div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="st-search">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <input type="text" placeholder="بحث..." />
