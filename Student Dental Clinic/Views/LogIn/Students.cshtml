    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ============================================================
        // البيانات الوهمية للتقارير
        // ============================================================
        const myReports = [
          {
            id: 1,
            caseType: 'حشو ضرسي',
            patient: 'سارة الحسن',
            date: '11 أبريل 2025',
            grade: 17, maxGrade: 20,
            status: 'graded',
            note: 'الطالب أظهر مهارة جيدة في التعامل مع الأدوات.',
            desc: 'تم إجراء الحشو الضرسي بنجاح باستخدام مادة الكومبوزيت على الضرس السادس السفلي الأيسر.',
          },
          {
            id: 2,
            caseType: 'خلع ضرس عقل',
            patient: 'محمد نور',
            date: '5 أبريل 2025',
            grade: 16, maxGrade: 20,
            status: 'graded',
            note: 'تم الخلع بطريقة صحيحة مع إعطاء إرشادات ما بعد الخلع.',
            desc: 'تم خلع ضرس العقل السفلي الأيمن بعد التخدير الموضعي بنجاح.',
          },
          {
            id: 3,
            caseType: 'تنظيف وتلميع',
            patient: 'ليلى خير',
            date: '29 مارس 2025',
            grade: null, maxGrade: 20,
            status: 'pending',
            note: null,
            desc: 'تم إجراء تنظيف شامل للأسنان وإزالة الجير وتلميع السطوح.',
          },
        ];

        // ============================================================
        // التنقل بين الفيوهات
        // ============================================================
        function showView(name) {
          // أخفِ كل الفيوهات
          document.querySelectorAll('.st-view').forEach(v => v.classList.remove('active'));
          document.getElementById('st-view-' + name).classList.add('active');

          // حدّث الرابط النشط في السيدبار
          document.querySelectorAll('.st-nav-link').forEach(l => {
            l.classList.toggle('active', l.getAttribute('onclick')?.includes("'" + name + "'"));
          });

          // حدّث عنوان الصفحة
          const titles = {
            'dashboard':      'لوحتي',
            'profile':        'ملفي الشخصي',
            'session':        'الجلسة القادمة',
            'reports':        'تقاريري',
            'upload':         'رفع تقرير جديد',
            'request':        'طلب حالة',
            'requests-list':  'طلباتي',
            'notifications':  'الإشعارات',
          };
          document.getElementById('stPageTitle').textContent = titles[name] || '';

          // رسم التقارير عند الانتقال إليها
          if (name === 'reports') renderMyReports();
        }

        // ============================================================
        // رسم كروت التقارير
        // ============================================================
        function renderMyReports(filter = 'all') {
          let data = myReports;
          if (filter === 'graded')  data = data.filter(r => r.status === 'graded');
          if (filter === 'pending') data = data.filter(r => r.status === 'pending');

          const bgColors = ['#dcfce7','#dbeafe','#fef9c3'];

          document.getElementById('myReportsGrid').innerHTML = data.map((r, i) => `
            <div class="col-md-4">
              <div class="st-report-card">

                <!-- صور قبل/بعد placeholder -->
                <div class="st-report-imgs">
                  <div class="st-img-slot" style="background:${bgColors[i % bgColors.length]};">
                    <div class="text-center" style="color:var(--st-muted);">
                      <i class="fa-solid fa-image fa-lg d-block mb-1"></i>
                      <span style="font-size:10px;font-weight:600;">قبل</span>
                    </div>
                    <span class="st-img-lbl">قبل</span>
                  </div>
                  <div class="st-img-slot" style="background:${bgColors[(i+1) % bgColors.length]};border-right:2px solid white;">
                    <div class="text-center" style="color:var(--st-muted);">
                      <i class="fa-solid fa-image fa-lg d-block mb-1"></i>
                      <span style="font-size:10px;font-weight:600;">بعد</span>
                    </div>
                    <span class="st-img-lbl">بعد</span>
                  </div>
                </div>

                <!-- معلومات التقرير -->
                <div class="p-3 border-bottom" style="border-color:#edf2f0 !important;">
                  <div style="font-size:14px;font-weight:700;margin-bottom:3px;">${r.caseType}</div>
                  <div style="font-size:11px;color:var(--st-muted);">
                    <i class="fa-solid fa-user me-1"></i>${r.patient} ·
                    <i class="fa-solid fa-calendar me-1 ms-1"></i>${r.date}
                  </div>
                  <div style="font-size:12px;color:#444;margin-top:8px;line-height:1.6;">
                    ${r.desc.substring(0, 80)}...
                  </div>
                  <!-- ملاحظة الدكتور إن وجدت -->
                  ${r.note ? `
                    <div class="mt-2 p-2 rounded" style="background:#f0fdf9;border:1px solid #a7f3d0;font-size:11px;color:#0d6e5c;">
                      <i class="fa-solid fa-comment me-1"></i><strong>الدكتور:</strong> ${r.note}
                    </div>
                  ` : ''}
                </div>

                <!-- العلامة أو حالة الانتظار -->
                <div class="d-flex align-items-center justify-content-between p-3">
                  <div>
                    <div style="font-size:10px;color:var(--st-muted);margin-bottom:2px;">الحالة</div>
                    ${r.status === 'graded'
                      ? `<span class="st-grade-badge grade-excellent"><i class="fa-solid fa-star me-1"></i>مُقيَّم</span>`
                      : `<span class="st-grade-badge grade-pending"><i class="fa-solid fa-clock me-1"></i>بانتظار الدكتور</span>`
                    }
                  </div>
                  ${r.grade !== null
                    ? `<div class="st-grade-circle">${r.grade}/${r.maxGrade}</div>`
                    : `<div class="st-grade-pending">?</div>`
                  }
                </div>
              </div>
            </div>
          `).join('');
        }

        // فلتر التقارير
        function filterMyReports(f, btn) {
          document.querySelectorAll('#st-view-reports .st-filter-tab').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          renderMyReports(f);
        }

        // ============================================================
        // مودال بيانات المريض + تبويباته
        // ============================================================
        function openPatientModal() {
          document.getElementById('patientModal').classList.add('open');
        }

        function closeStModal(id) {
          document.getElementById(id).classList.remove('open');
        }

        // إغلاق بالنقر على الخلفية
        document.querySelectorAll('.st-modal-overlay').forEach(m => {
          m.addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('open');
          });
        });

        // تبديل التبويبات في مودال المريض
        function switchTab(el, tabId) {
          // أخفِ كل التبويبات
          ['pt-personal','pt-medical','pt-notes'].forEach(id => {
            document.getElementById(id).classList.add('d-none');
          });
          // أزل active من كل الروابط
          document.querySelectorAll('#patientModal .nav-link').forEach(l => l.classList.remove('active'));
          // أظهر المحدد
          document.getElementById(tabId).classList.remove('d-none');
          el.classList.add('active');
        }

        // ============================================================
        // نموذج رفع التقرير
        // ============================================================

        // فتح dialog اختيار الملف
        function triggerUpload(inputId) {
          document.getElementById(inputId).click();
        }

        // معاينة الصورة بعد الاختيار
        function previewImg(input, zoneId, previewId) {
          if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
              const preview = document.getElementById(previewId);
              preview.src = e.target.result;
              preview.classList.remove('d-none');
              // غيّر لون المنطقة
              document.getElementById(zoneId).style.borderColor = 'var(--st-accent)';
              document.getElementById(zoneId).style.background  = '#dcfce7';
            };
            reader.readAsDataURL(input.files[0]);
          }
        }

        // إظهار/إخفاء حقل المضاعفات
        function toggleComp(show) {
          document.getElementById('compDetail').classList.toggle('d-none', !show);
          // إعادة إخفاء عند اختيار "لا"
          document.getElementById('comp-no').addEventListener('change', () => {
            document.getElementById('compDetail').classList.add('d-none');
          });
        }

        // اختيار التقييم الذاتي
        function setSelfGrade(btn, val) {
          document.querySelectorAll('#st-view-upload .st-filter-tab').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        }

        // إرسال التقرير
        function submitReport() {
          showStToast('تم رفع التقرير بنجاح وأُرسل للدكتور! 🎉', 'fa-check-circle');
          setTimeout(() => showView('reports'), 1200);
        }

        // ============================================================
        // نموذج طلب الحالة
        // ============================================================
        function submitRequest() {
          const name = document.getElementById('req-name').value.trim();
          const phone = document.getElementById('req-phone').value.trim();
          const relation = document.getElementById('req-relation').value;
          const treatment = document.getElementById('req-treatment').value.trim();

          // تحقق بسيط
          if (!name || !phone || !relation || !treatment) {
            showStToast('يرجى ملء جميع الحقول المطلوبة', 'fa-exclamation-triangle');
            return;
          }

          showStToast(`تم إرسال طلب حالة ${name} للدكتور بنجاح!`, 'fa-paper-plane');
          // مسح الحقول
          ['req-name','req-phone','req-treatment','req-reason'].forEach(id => {
            document.getElementById(id).value = '';
          });
          document.getElementById('req-relation').value = '';
          setTimeout(() => showView('requests-list'), 1200);
        }

        // ============================================================
        // Toast
        // ============================================================
        function showStToast(msg, icon = 'fa-check') {
          const c = document.getElementById('stToastContainer');
          const t = document.createElement('div');
          t.className = 'st-toast-item';
          t.innerHTML = `<i class="fa-solid ${icon}" style="color:var(--st-accent);"></i>${msg}`;
          c.appendChild(t);
          setTimeout(() => {
            t.style.opacity = '0'; t.style.transition = 'opacity .3s';
            setTimeout(() => t.remove(), 300);
          }, 3200);
        }

        // ============================================================
        // تشغيل أولي
        // ============================================================
        renderMyReports(); // لتكون جاهزة عند أول دخول لصفحة التقارير
    </script>
